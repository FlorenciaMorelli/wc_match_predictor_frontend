# Backend real al que el proxy de Next reenvía "/api/*" (server-side, NO se
# expone al navegador). Ver el proxy en next.config.ts.
API_BASE_URL=https://wc-match-predictor.onrender.com

# URL pública del frontend (para metadataBase / OG images).
# En producción: la URL real del deploy (p. ej. https://wc2026.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
